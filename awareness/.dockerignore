# .dockerignore — trims the build context sent to the Docker daemon.
#
# The image is built by deploy/Dockerfile with this directory (awareness/) as
# the context. Stage 1 only needs: package.json + package-lock.json (for
# npm ci), scripts/build-dist.mjs, and the source that build-dist.mjs
# allowlists (the *.html entrypoints, js/, css/, assets/, templates/).
# Everything below is either rebuilt, dev-only, or never shipped — keeping it
# out of the context makes builds faster and avoids baking junk into layers.
#
# DO NOT add: package.json, package-lock.json, scripts/, js/, css/, assets/,
# templates/, the entry *.html files, health.html, README.md, LICENSE.

# ── Dependencies (Dockerfile runs `npm ci` itself) ───────────────────────────
node_modules/

# ── Build output (regenerated by build-dist.mjs in-image) ────────────────────
dist/

# ── Test / audit / report artifacts ──────────────────────────────────────────
tests/
playwright-report/
test-results/
.playwright-mcp/
baseline-critical-path-audit-results.json
playwright.config.js
eslint.config.js
babel.json

# ── Dev-only data, logs, and scratch dirs ────────────────────────────────────
ensemble-logs/
graphify-out/
experiments/
results/
nessus_advisory/
docs/
# NOTE: article-seed/ and vendor/ are intentionally NOT ignored — build-dist.mjs
# ships them (index.html loads article-seed/articles.js, vendor/jszip.min.js, and
# vendor/qrcode.min.js via <script src>), so they must stay in the build context.

# ── Large binaries / archives that never ship ────────────────────────────────
# NOTE: do NOT blanket-exclude image extensions here — assets/ and templates/
# carry 38 images that build-dist.mjs ships into the artifact. Only the loose
# root-level archives below are safe to drop.
*.zip
*.pptx

# ── Loose dev outputs at the root (not in build-dist's allowlist) ────────────
gen_*.html
changes.txt
RESTRUCTURE.md

# ── VCS / editor / tooling metadata ──────────────────────────────────────────
.git/
.gitignore
.vscode/
.agents/
.claude/
.nvmrc

# ── Secrets — never let these into a build layer ─────────────────────────────
.env
.env.*
*.local.*
**/*.local
