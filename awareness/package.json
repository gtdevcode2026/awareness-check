{
  "scripts": {
    "serve": "node scripts/dev_servers.mjs",
    "serve:static": "serve -l tcp://127.0.0.1:4173 .",
    "relay:graph": "node scripts/graph_relay_server.mjs",
    "relay:smtp": "python scripts/smtp_relay_server.py",
    "relay:ai": "python scripts/ai_relay_server.py",
    "send:advisory": "python nessus_advisory/cve_alert.py",
    "ensemble:logs": "node scripts/ensemble_log_server.mjs",
    "lint": "eslint .",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:e2e": "playwright test",
    "security:test": "node --test tests/unit/security.test.js",
    "audit:baseline": "node scripts/run_with_static_server.js node scripts/run_baseline_critical_path_audit.js",
    "audit:deps": "npm audit --audit-level=moderate",
    "build:dist": "node scripts/build-dist.mjs",
    "deploy:server": "node scripts/deploy-server.mjs",
    "deploy:docker": "node scripts/deploy-docker.mjs",
