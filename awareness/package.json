  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.0",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "jsdom": "^26.0.0",
    "marked": "^18.0.4",
    "serve": "^14.2.6"
  }
